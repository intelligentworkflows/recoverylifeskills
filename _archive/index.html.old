  <link rel="stylesheet" href="style.css">
  <style>
    header { padding: 16px 0 8px; }
    main { margin: 32px auto 0; }

.intro {
      background: var(--accent-light);
      border: 1px solid var(--border-blue);
      border-left: 4px solid var(--accent);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-bottom: 32px;
      font-size: 1rem;
      color: var(--text);
    }

    .intro p { margin-bottom: 12px; }
    .intro p:last-child { margin-bottom: 0; }

    .treatments {
      list-style: none;
      margin-top: 10px;
      columns: 2;
      column-gap: 16px;
    }

    .treatments li {
      padding: 3px 0;
      font-size: 0.95rem;
      break-inside: avoid;
    }

    .treatments li::before {
      content: "•";
      color: var(--accent);
      font-weight: 700;
      margin-right: 8px;
    }

    .faq-section h2 {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
    }

    details {
      background: var(--surface);
      border: 1px solid var(--border-blue);
      border-radius: var(--radius);
      margin-bottom: 8px;
      overflow: hidden;
    }

    details[open] {
      border-color: var(--accent);
    }

    summary {
      cursor: pointer;
      padding: 16px 20px;
      font-weight: 600;
      font-size: 1rem;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      user-select: none;
    }

    summary::-webkit-details-marker { display: none; }

    summary::after {
      content: "+";
      font-size: 1.3rem;
      font-weight: 300;
      color: var(--accent);
      flex-shrink: 0;
      line-height: 1;
    }

    details[open] summary::after {
      content: "−";
    }

    summary:hover {
      background: var(--accent-light);
    }

    .answer {
      padding: 0 20px 20px;
      color: var(--text);
      font-size: 0.975rem;
    }

    .answer p { margin-top: 12px; }
    .answer p:first-child { margin-top: 0; }

    .answer a {
      color: var(--accent);
      word-break: break-word;
    }

    .answer table {
      border-collapse: collapse;
      width: 100%;
      font-size: 0.95rem;
    }

    .answer th {
      padding: 5px 12px;
      text-align: left;
      border: 1px solid var(--accent);
      background: var(--accent-light);
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--muted);
    }

    .answer td {
      padding: 5px 12px;
      vertical-align: top;
      border: 1px solid var(--accent);
    }

    .answer td:first-child {
      white-space: nowrap;
      color: var(--muted);
      font-weight: 600;
    }

    .toc {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-bottom: 16px;
    }

    .toc-label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .toc ul {
      list-style: disc;
      margin: 0;
      padding-left: 1.25rem;
      columns: 2;
      column-gap: 16px;
    }

    .toc li {
      font-size: 1.05rem;
      padding: 3px 0;
      break-inside: avoid;
    }

    .toc a {
      color: #1a6fc4;
      text-decoration: none;
    }

    .toc a:hover {
      text-decoration: underline;
    }
  </style>
</head>
